# ═══════════════════════════════════════════════════════════════════════════════
# Mirror Nexus Bot — Environment Configuration Example
# Developer: @Venuboyy
# Copy this file: cp .env.example .env
# Then fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ── Bot Credentials (REQUIRED) ────────────────────────────────────────────────
BOT_TOKEN=
API_ID=0
API_HASH=

# ── Owner / Admins (REQUIRED) ─────────────────────────────────────────────────
OWNER_ID=0
SUDO_USERS=

# ── Force Subscribe Channels (Optional) ──────────────────────────────────────
FORCE_SUB_CHANNEL_1=
FORCE_SUB_CHANNEL_2=

# ── MongoDB (REQUIRED) ───────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=mirrornexus

# ── Downloads Configuration ──────────────────────────────────────────────────
DOWNLOAD_DIR=/tmp/downloads
MAX_SPLIT_SIZE=2000000000
WORKERS=500

# ── Sticker / Welcome Images (Optional) ──────────────────────────────────────
STICKER_ID=
WELCOME_IMG_API=
MASSAGE_IMG_URL=

# ── Aria2c RPC Configuration (Optional) ──────────────────────────────────────
ARIA2C_HOST=http://localhost
ARIA2C_PORT=6800
ARIA2C_SECRET=

# ── Google Drive (Optional) ──────────────────────────────────────────────────
GDRIVE_FOLDER_ID=
TOKEN_PICKLE_PATH=token.pickle

# ── RClone (Optional) ────────────────────────────────────────────────────────
RCLONE_PATH=rclone
RCLONE_CONFIG_PATH=rclone.conf
